pkgname=autologin
pkgver=0.1
pkgrel=1
pkgdesc="Prepare autologin for at first boot"
arch=('any')
license=('GPL-2.0-only')
depends=('')
source=('autologin-setup.service')
sha256sums=('719691376dd939f07c5ad462f795fa8a650137ae701b38e4dca33d0038595c1a')

package() {
    mkdir -p "$pkgdir/usr/lib/systemd/system"
    install -m 755 "$srcdir/autologin-setup.service" "$pkgdir/usr/lib/systemd/system/"
}
