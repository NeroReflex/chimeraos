pkgname=autologin
pkgver=0.1
pkgrel=1
pkgdesc="Prepare autologin for at first boot"
arch=('any')
license=('GPL-2.0-only')
depends=('')
source=(
    'autologin-setup.service'
    'autologin-firstboot.sh'
)
sha256sums=(
    '719691376dd939f07c5ad462f795fa8a650137ae701b38e4dca33d0038595c1a' # autologin-setup.service
    'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855' # autologin-firstboot.sh
)

package() {
    mkdir -p "$pkgdir/usr/bin"
    install -m 755 "$srcdir/autologin-firstboot.sh" "$pkgdir/usr/bin/"

    mkdir -p "$pkgdir/usr/lib/systemd/system"
    install -m 644 "$srcdir/autologin-setup.service" "$pkgdir/usr/lib/systemd/system/"
}
